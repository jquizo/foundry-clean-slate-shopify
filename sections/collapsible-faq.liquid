{%- comment -%} sections/collapsible-faq.liquid {%- endcomment -%}

<section class="collapsible-faq" data-section-id="{{ section.id }}">
  <div class="container container--narrow">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="faq__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="faq__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="faq__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="faq__list">
      {%- for block in section.blocks -%}
        <details class="faq__item" {{ block.shopify_attributes }}>
          <summary class="faq__question">
            {{- block.settings.question -}}
            <span class="faq__icon" aria-hidden="true"></span>
          </summary>
          <div class="faq__answer rte">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>

  </div>
</section>

{% style %}
  .collapsible-faq {
    padding-block: var(--section-padding-block);
  }

  .faq__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .faq__heading {
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
  }

  .faq__subheading {
    font-size: var(--text-lg);
    color: var(--color-text-subtle);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-4);
    max-width: 56ch;
    margin-inline: auto;
  }

  /* --- List --- */

  .faq__list {
    border-top: var(--border);
  }

  /* --- Item --- */

  .faq__item {
    border-bottom: var(--border);
  }

  /* --- Question (summary) --- */

  .faq__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-5);
    cursor: pointer;
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-subtle);
    list-style: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question:hover,
  details[open] > .faq__question {
    color: var(--color-text);
  }

  /* --- Icon --- */

  .faq__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-primary);
    font-size: var(--text-xl);
    line-height: 1;
  }

  .faq__icon::before {
    content: "+";
  }

  details[open] .faq__icon::before {
    content: "−";
  }

  /* --- Answer --- */

  .faq__answer {
    padding-bottom: var(--space-5);
    color: var(--color-text-subtle);
  }
{% endstyle %}

{% schema %}
{
  "name": "Collapsible FAQ",
  "tag": "section",
  "class": "section-collapsible-faq",
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "placeholder": "Frequently asked questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "placeholder": "A short line supporting your heading"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Frequently asked question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Share the answer to a common question about your products or store.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collapsible FAQ",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}
