{% comment %}
  sections/collection.liquid
  Renders the main collection/category page.
  Looping and pagination are controlled by the {% paginate %} tag.
{% endcomment %}

{%- liquid
  assign grid_block       = section.blocks | where: 'type', 'product_grid'      | first
  assign header_block     = section.blocks | where: 'type', 'collection_header' | first
  assign sort_block       = section.blocks | where: 'type', 'sort_and_filter'   | first
  assign pagination_block = section.blocks | where: 'type', 'pagination'        | first

  assign columns_desktop = grid_block.settings.columns_desktop   | default: 3
  assign columns_mobile  = grid_block.settings.columns_mobile    | default: 2
  assign per_page        = grid_block.settings.products_per_page | default: 24
-%}

{%- paginate collection.products by per_page -%}

<div class="collection" id="CollectionSection-{{ section.id }}">

  {%- comment -%} ── COLLECTION HEADER ── {%- endcomment -%}
  {%- if header_block != blank -%}
    <header
      class="collection__header"
      {{ header_block.shopify_attributes }}
    >
      <h1 class="collection__title">{{ collection.title }}</h1>

      {%- if header_block.settings.show_product_count -%}
        <p class="collection__count">
          {{ collection.products_count }}
          {{ 'collections.general.product_count' | t: count: collection.products_count }}
        </p>
      {%- endif -%}

      {%- if header_block.settings.show_description and collection.description != blank -%}
        <div class="collection__description rte">
          {{ collection.description }}
        </div>
      {%- endif -%}
    </header>
  {%- endif -%}

  {%- comment -%} ── SORT & FILTER ── {%- endcomment -%}
  {%- if sort_block != blank and sort_block.settings.show_sort -%}
    <div
      class="collection__toolbar"
      {{ sort_block.shopify_attributes }}
    >
      <form class="collection__sort-form">
        <label class="collection__sort-label" for="SortBy-{{ section.id }}">
          {{ 'collections.sorting.label' | t }}
        </label>
        <select
          id="SortBy-{{ section.id }}"
          class="collection__sort-select"
          name="sort_by"
          onchange="this.form.submit()"
        >
          {%- for option in collection.sort_options -%}
            <option
              value="{{ option.value }}"
              {%- if option.value == collection.sort_by %} selected{%- endif -%}
            >
              {{- option.name -}}
            </option>
          {%- endfor -%}
        </select>
      </form>
    </div>
  {%- endif -%}

  {%- comment -%} ── PRODUCT GRID ── {%- endcomment -%}
  {%- if grid_block != blank -%}
    <div
      class="collection__grid"
      style="
        --columns-desktop: {{ columns_desktop }};
        --columns-mobile: {{ columns_mobile }};
      "
      {{ grid_block.shopify_attributes }}
    >
      {%- for product in collection.products -%}
        <article class="product-card">
          <a
            class="product-card__image-wrapper"
            href="{{ product.url | within: collection }}"
            aria-label="{{ product.title | escape }}"
          >
            {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 600 | image_tag: class: 'product-card__image', alt: product.featured_image.alt, loading: 'lazy' }}
            {%- else -%}
              <div class="product-card__image product-card__image--placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </a>

          <div class="product-card__info">
            <h2 class="product-card__title">
              <a href="{{ product.url | within: collection }}">{{ product.title }}</a>
            </h2>

            <p class="product-card__price">
              {%- if product.compare_at_price > product.price -%}
                <s class="product-card__price--compare">{{ product.compare_at_price | money }}</s>
                <span class="product-card__price--sale">{{ product.price | money }}</span>
              {%- else -%}
                <span>{{ product.price | money }}</span>
              {%- endif -%}
            </p>
          </div>
        </article>
      {%- else -%}
        <p class="collection__empty">
          {{ 'collections.general.no_matches' | t }}
        </p>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── PAGINATION ── {%- endcomment -%}
  {%- if pagination_block != blank and paginate.pages > 1 -%}
    <nav
      class="collection__pagination"
      aria-label="{{ 'general.pagination.label' | t }}"
      {{ pagination_block.shopify_attributes }}
    >
      {{ paginate | default_pagination }}
    </nav>
  {%- endif -%}

</div>

{%- endpaginate -%}

{% style %}
  .collection {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-4);
  }

  .collection__header {
    margin-bottom: var(--space-8);
    text-align: center;
  }

  .collection__title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    margin-bottom: var(--space-2);
  }

  .collection__count {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-4);
  }

  .collection__description {
    max-width: 60ch;
    margin: 0 auto;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .collection__toolbar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-bottom: var(--space-6);
    gap: var(--space-3);
  }

  .collection__sort-form {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .collection__sort-label {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .collection__sort-select {
    font-size: var(--font-size-sm);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background-color: var(--color-background);
    color: var(--color-text);
    cursor: pointer;
  }

  .collection__sort-select:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .collection__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns-mobile), 1fr);
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .collection__grid {
      grid-template-columns: repeat(var(--columns-desktop), 1fr);
    }
  }

  .collection__empty {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-16) 0;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .product-card__image-wrapper {
    display: block;
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 1 / 1;
    background-color: var(--color-surface);
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card__image-wrapper:hover .product-card__image {
    transform: scale(1.04);
  }

  .product-card__image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-text-muted);
  }

  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .product-card__title {
    font-size: var(--font-size-base);
    font-weight: 500;
    line-height: 1.3;
  }

  .product-card__title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .product-card__title a:hover {
    text-decoration: underline;
  }

  .product-card__price {
    font-size: var(--font-size-sm);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .product-card__price--compare {
    color: var(--color-text-muted);
    text-decoration: line-through;
  }

  .product-card__price--sale {
    color: var(--color-error, #c0392b);
    font-weight: 600;
  }

  .collection__pagination {
    margin-top: var(--space-12);
    display: flex;
    justify-content: center;
  }

  .collection__pagination .pagination {
    display: flex;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .collection__pagination .pagination li a,
  .collection__pagination .pagination li span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .collection__pagination .pagination li a:hover {
    background-color: var(--color-surface);
    border-color: var(--color-text);
  }

  .collection__pagination .pagination li.active span {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-primary-contrast, #fff);
    font-weight: 600;
  }
{% endstyle %}

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-collection",
  "blocks": [
    {
      "type": "collection_header",
      "name": "Collection header",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_description",
          "label": "Show collection description",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_product_count",
          "label": "Show product count",
          "default": true
        }
      ]
    },
    {
      "type": "sort_and_filter",
      "name": "Sort and filter",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_sort",
          "label": "Show sort dropdown",
          "default": true
        }
      ]
    },
    {
      "type": "product_grid",
      "name": "Product grid",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "columns_desktop",
          "label": "Columns on desktop",
          "min": 2,
          "max": 4,
          "step": 1,
          "default": 3
        },
        {
        "type": "range",
        "id": "columns_mobile",
        "label": "Columns on mobile",
        "min": 1,
        "max": 3,
        "step": 1,
        "default": 2
        },
        {
          "type": "range",
          "id": "products_per_page",
          "label": "Products per page",
          "min": 8,
          "max": 48,
          "step": 4,
          "default": 24
        }
      ]
    },
    {
      "type": "pagination",
      "name": "Pagination",
      "limit": 1,
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Collection"
    }
  ]
}
{% endschema %}
