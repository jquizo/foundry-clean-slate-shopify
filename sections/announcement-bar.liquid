{%- comment -%} sections/announcement-bar.liquid {%- endcomment -%}

{%- if section.settings.message != blank -%}
  <div
    class="announcement-bar"
    data-announcement-bar
    style="
      --announcement-bg: {{ section.settings.background_color }};
      --announcement-text: {{ section.settings.text_color }};
    "
    role="region"
    aria-label="Announcement"
  >
    <div class="container announcement-bar__inner">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="announcement-bar__message">
          {{ section.settings.message }}
        </a>
      {%- else -%}
        <p class="announcement-bar__message">{{ section.settings.message }}</p>
      {%- endif -%}

      {%- if section.settings.show_toggle -%}
        <button
          type="button"
          class="announcement-bar__toggle"
          data-announcement-toggle
          aria-label="{{ 'sections.announcement_bar.toggle_collapse' | t }}"
          aria-expanded="true"
        >
          {%- render 'icon', icon: 'chevron-up', size: 16 -%}
        </button>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

<script>
  (function () {
    var bar    = document.querySelector('[data-announcement-bar]');
    var btn    = document.querySelector('[data-announcement-toggle]');
    var key    = 'foundry-announcement-{{ section.id }}';
    var labelCollapse = {{ 'sections.announcement_bar.toggle_collapse' | t | json }};
    var labelExpand   = {{ 'sections.announcement_bar.toggle_expand'   | t | json }};

    if (!bar) return;

    function setCollapsed(collapsed) {
      bar.classList.toggle('announcement-bar--collapsed', collapsed);
      if (btn) {
        btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        btn.setAttribute('aria-label', collapsed ? labelExpand : labelCollapse);
      }
    }

    if (localStorage.getItem(key) === 'collapsed') {
      setCollapsed(true);
    }

    if (btn) {
      btn.addEventListener('click', function () {
        var nowCollapsed = !bar.classList.contains('announcement-bar--collapsed');
        setCollapsed(nowCollapsed);
        if (nowCollapsed) {
          localStorage.setItem(key, 'collapsed');
        } else {
          localStorage.removeItem(key);
        }
      });
    }
  })();
</script>

{% style %}
  .announcement-bar {
    background-color: var(--announcement-bg);
    color: var(--announcement-text);
    overflow: hidden;
    transition: padding var(--duration-fast) var(--ease-out);
  }

  .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding-block: var(--space-3);
    position: relative;
    transition: padding var(--duration-fast) var(--ease-out);
  }

  .announcement-bar__message {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    text-align: center;
    color: inherit;
    max-width: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  a.announcement-bar__message:hover {
    text-decoration: underline;
    color: inherit;
  }

  /* ── Toggle button ── */

  .announcement-bar__toggle {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    color: inherit;
    opacity: 0.7;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .announcement-bar__toggle:hover {
    opacity: 1;
  }

  .announcement-bar__toggle svg {
    transition: transform var(--duration-fast) var(--ease-out);
  }

  /* ── Collapsed state ── */

  .announcement-bar--collapsed .announcement-bar__inner {
    padding-block: var(--space-1);
  }

  .announcement-bar--collapsed .announcement-bar__message {
    display: none;
  }

  .announcement-bar--collapsed .announcement-bar__toggle svg {
    transform: rotate(180deg);
  }
{% endstyle %}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "div",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Welcome to our store! Free shipping on orders over $50."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "checkbox",
      "id": "show_toggle",
      "label": "Show collapse toggle",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0ea5e9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
