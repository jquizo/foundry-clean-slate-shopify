{%- comment -%} sections/announcement-bar.liquid {%- endcomment -%}

{%- if section.settings.message != blank -%}
  <div
    class="announcement-bar"
    data-announcement-bar
    style="
      --announcement-bg: {{ section.settings.background_color }};
      --announcement-text: {{ section.settings.text_color }};
    "
    role="region"
    aria-label="Announcement"
  >
    <div class="container announcement-bar__inner">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="announcement-bar__message">
          {{ section.settings.message }}
        </a>
      {%- else -%}
        <p class="announcement-bar__message">{{ section.settings.message }}</p>
      {%- endif -%}

      {%- if section.settings.show_dismiss -%}
        <button
          type="button"
          class="announcement-bar__dismiss"
          data-announcement-dismiss
          aria-label="{{ 'sections.announcement_bar.dismiss' | t }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

<script>
  (function () {
    var bar = document.querySelector('[data-announcement-bar]');
    var btn = document.querySelector('[data-announcement-dismiss]');
    var storageKey = 'foundry-announcement-{{ section.id }}';

    if (!bar) return;

    if (localStorage.getItem(storageKey) === 'dismissed') {
      bar.hidden = true;
      return;
    }

    if (btn) {
      btn.addEventListener('click', function () {
        bar.hidden = true;
        localStorage.setItem(storageKey, 'dismissed');
      });
    }
  })();
</script>

{% style %}
  .announcement-bar {
    background-color: var(--announcement-bg);
    color: var(--announcement-text);
  }

  .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding-block: var(--space-3);
    position: relative;
  }

  .announcement-bar__message {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    text-align: center;
    color: inherit;
    max-width: none;
  }

  a.announcement-bar__message:hover {
    text-decoration: underline;
    color: inherit;
  }

  .announcement-bar__dismiss {
    position: absolute;
    right: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: inherit;
    opacity: 0.7;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .announcement-bar__dismiss:hover {
    opacity: 1;
  }
{% endstyle %}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "div",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Welcome to our store! Free shipping on orders over $50."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "checkbox",
      "id": "show_dismiss",
      "label": "Show dismiss button",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0ea5e9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
