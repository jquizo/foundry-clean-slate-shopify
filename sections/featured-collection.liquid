{%- comment -%} sections/featured-collection.liquid {%- endcomment -%}

{%- liquid
  assign fc_collection = collections[section.settings.collection]
  assign product_limit = section.settings.product_limit
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
-%}

<section class="featured-collection" data-section-id="{{ section.id }}">
  <div class="container">

    {%- if section.settings.heading != blank -%}
      <div class="featured-collection__header">
        <h2 class="featured-collection__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.show_view_all and fc_collection != blank -%}
          <a href="{{ fc_collection.url }}" class="featured-collection__view-all">
            {{ 'actions.view_all' | t }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if fc_collection != blank and fc_collection.products_count > 0 -%}
      <div
        class="featured-collection__grid"
        style="
          --columns-desktop: {{ columns_desktop }};
          --columns-mobile: {{ columns_mobile }};
        "
      >
        {%- for product in fc_collection.products limit: product_limit -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% style %}
  .featured-collection {
    padding-block: var(--section-padding-block);
  }

  .featured-collection__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .featured-collection__heading {
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .featured-collection__view-all {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-subtle);
    white-space: nowrap;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .featured-collection__view-all:hover {
    color: var(--color-text);
  }

  .featured-collection__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns-mobile), 1fr);
    gap: var(--grid-gap);
  }

  @media (min-width: 768px) {
    .featured-collection__grid {
      grid-template-columns: repeat(var(--columns-desktop), 1fr);
    }
  }

  /* ── Product card ── */

  .product-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .product-card__image-wrapper {
    display: block;
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 1 / 1;
    background-color: var(--color-bg-subtle);
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .product-card__image-wrapper:hover .product-card__image {
    transform: scale(1.04);
  }

  .product-card__image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-text-muted);
  }

  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .product-card__title {
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
    line-height: var(--leading-snug);
  }

  .product-card__title a {
    color: var(--color-text);
  }

  .product-card__title a:hover {
    text-decoration: underline;
  }

  .product-card__price {
    font-size: var(--text-sm);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .product-card__price--compare {
    color: var(--color-text-muted);
    text-decoration: line-through;
  }

  .product-card__price--sale {
    color: var(--color-error);
    font-weight: var(--font-weight-semibold);
  }
{% endstyle %}

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Number of products",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "min": 1,
      "max": 2,
      "step": 1,
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
