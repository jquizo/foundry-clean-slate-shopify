{%- liquid
  assign blog_source  = blogs[section.settings.blog]
  assign post_limit   = section.settings.post_limit   | default: 3
  assign show_author  = section.settings.show_author
  assign show_date    = section.settings.show_date
  assign show_excerpt = section.settings.show_excerpt
-%}

<section class="blog-posts" data-section-id="{{ section.id }}">
  <div class="container">

    {%- comment -%} ── Header ── {%- endcomment -%}
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="blog-posts__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="blog-posts__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="blog-posts__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.show_view_all and blog_source != blank -%}
          <a href="{{ blog_source.url }}" class="blog-posts__view-all">
            {{ 'actions.view_all' | t }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Grid ── {%- endcomment -%}
    {%- if blog_source != blank and blog_source.articles_count > 0 -%}

      <ul class="blog-posts__grid" role="list">
        {%- for article in blog_source.articles limit: post_limit -%}
          <li class="blog-post-card">

            {%- if article.image -%}
              <a class="blog-post-card__image-wrapper" href="{{ article.url }}" aria-hidden="true" tabindex="-1">
                {{
                  article.image
                  | image_url: width: 800
                  | image_tag:
                    class: 'blog-post-card__image',
                    alt: article.image.alt | default: article.title,
                    loading: 'lazy',
                    widths: '400, 600, 800'
                }}
              </a>
            {%- endif -%}

            <div class="blog-post-card__body">

              {%- if show_author or show_date -%}
                <p class="blog-post-card__meta">
                  {%- if show_author -%}
                    <span>{{ article.author }}</span>
                  {%- endif -%}
                  {%- if show_author and show_date -%}
                    <span class="blog-post-card__meta-sep" aria-hidden="true">&middot;</span>
                  {%- endif -%}
                  {%- if show_date -%}
                    <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                      {{- article.published_at | date: '%B %e, %Y' -}}
                    </time>
                  {%- endif -%}
                </p>
              {%- endif -%}

              <h3 class="blog-post-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>

              {%- if show_excerpt and article.excerpt_or_content != blank -%}
                <p class="blog-post-card__excerpt">
                  {{ article.excerpt_or_content | strip_html | truncate: 160 }}
                </p>
              {%- endif -%}

              <a class="blog-post-card__read-more" href="{{ article.url }}">
                {{ 'blog.general.read_more' | t }}
              </a>

            </div>
          </li>
        {%- endfor -%}
      </ul>

    {%- else -%}
      <p class="blog-posts__empty">{{ 'blog.general.no_posts' | t }}</p>
    {%- endif -%}

  </div>
</section>

{% style %}
  .blog-posts {
    padding-block: var(--section-padding-block);
  }

  .blog-posts__header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-2) var(--space-4);
    align-items: start;
    margin-bottom: var(--space-10);
  }

  .blog-posts__heading {
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-text);
    grid-column: 1;
    margin: 0;
  }

  .blog-posts__subheading {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    grid-column: 1;
    margin: 0;
  }

  .blog-posts__view-all {
    grid-column: 2;
    grid-row: 1;
    align-self: center;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-subtle);
    white-space: nowrap;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .blog-posts__view-all:hover {
    color: var(--color-text);
  }

  .blog-posts__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-8);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog-posts__empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-16) 0;
  }

  /* ── Article card ── */

  .blog-post-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .blog-post-card__image-wrapper {
    display: block;
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 3 / 2;
    background-color: var(--color-bg-subtle);
  }

  .blog-post-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .blog-post-card__image-wrapper:hover .blog-post-card__image {
    transform: scale(1.04);
  }

  .blog-post-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .blog-post-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin: 0;
  }

  .blog-post-card__meta-sep {
    color: var(--color-text-muted);
  }

  .blog-post-card__title {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    line-height: var(--leading-snug);
    margin: 0;
  }

  .blog-post-card__title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .blog-post-card__title a:hover {
    text-decoration: underline;
  }

  .blog-post-card__excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .blog-post-card__read-more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-primary);
    margin-top: auto;
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .blog-post-card__read-more:hover {
    opacity: 0.75;
  }
{% endstyle %}

{% schema %}
{
  "name": "Blog posts",
  "tag": "section",
  "class": "section-blog-posts",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the blog"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "Number of posts",
      "min": 2,
      "max": 9,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Blog posts"
    }
  ]
}
{% endschema %}
