{%- comment -%} sections/hero.liquid {%- endcomment -%}

{%- liquid
  assign text_align = section.settings.text_alignment
  assign content_position = section.settings.content_position
  assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0
  case section.settings.button_size
    when 'small'
      assign btn_padding   = 'var(--space-2) var(--space-5)'
      assign btn_font_size = 'var(--text-xs)'
    when 'large'
      assign btn_padding   = 'var(--space-4) var(--space-10)'
      assign btn_font_size = 'var(--text-base)'
    else
      assign btn_padding   = 'var(--space-3) var(--space-8)'
      assign btn_font_size = 'var(--text-sm)'
  endcase
-%}

<section
  class="hero hero--{{ content_position }}"
  data-section-id="{{ section.id }}"
  style="--hero-min-height: {{ section.settings.min_height }}vh;"
>

  {%- comment -%} Background {%- endcomment -%}
  {%- if section.settings.bg_video != blank -%}
    <div class="hero__media" aria-hidden="true">
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        src="{{ section.settings.bg_video }}"
      ></video>
      {%- if section.settings.bg_image != blank -%}
        {{
          section.settings.bg_image
          | image_url: width: 1920
          | image_tag:
            class: 'hero__image',
            alt: '',
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '100vw'
        }}
      {%- endif -%}
    </div>
  {%- elsif section.settings.bg_image != blank -%}
    <div class="hero__media" aria-hidden="true">
      {{
        section.settings.bg_image
        | image_url: width: 1920
        | image_tag:
          class: 'hero__image',
          alt: '',
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw'
      }}
    </div>
  {%- endif -%}

  {%- comment -%} Overlay {%- endcomment -%}
  {%- if section.settings.show_overlay -%}
    <div class="hero__overlay"></div>
  {%- endif -%}

  {%- comment -%} Content {%- endcomment -%}
  <div class="container hero__container">
    <div class="hero__content hero__content--{{ text_align }}">

      {%- if section.settings.eyebrow != blank -%}
        <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.btn_label != blank and section.settings.btn_url != blank -%}
        <div class="hero__actions">
          <a
            href="{{ section.settings.btn_url }}"
            class="btn btn--primary"
          >
            {{ section.settings.btn_label }}
          </a>
          {%- if section.settings.btn_secondary_label != blank and section.settings.btn_secondary_url != blank -%}
            <a
              href="{{ section.settings.btn_secondary_url }}"
              class="btn btn--secondary"
            >
              {{ section.settings.btn_secondary_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- if section.settings.show_scroll_indicator -%}
    <div class="hero__scroll-indicator" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 9l6 6 6-6"/>
      </svg>
    </div>
  {%- endif -%}

</section>

{% style %}
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: var(--hero-min-height, 80vh);
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  /* --- Content position --- */

  .hero--top    { align-items: flex-start; padding-top: var(--section-padding-block); }
  .hero--middle { align-items: center; }
  .hero--bottom { align-items: flex-end; padding-bottom: var(--section-padding-block); }

  /* --- Background media --- */

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image,
  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.bg_image_position }};
  }

  /* --- Overlay --- */

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};
  }

  /* --- Container --- */

  .hero__container {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-block: var(--section-padding-block);
  }

  /* --- Content --- */

  .hero__content {
    max-width: {{ section.settings.content_max_width }}px;
  }

  .hero__content--center {
    margin-inline: auto;
    text-align: center;
  }

  .hero__content--right {
    margin-left: auto;
    text-align: right;
  }

  /* --- Eyebrow --- */

  .hero__eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
    max-width: none;
  }

  .hero--has-media .hero__eyebrow {
    color: var(--color-white);
    opacity: 0.85;
  }

  /* --- Heading --- */

  .hero__heading {
    font-size: {{ section.settings.heading_size }};
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: {{ section.settings.text_color }};
    margin-bottom: var(--space-4);
  }

  /* --- Subheading --- */

  .hero__subheading {
    font-size: var(--text-lg);
    color: {{ section.settings.text_color }};
    opacity: 0.85;
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
    max-width: 52ch;
  }

  .hero__content--center .hero__subheading {
    margin-inline: auto;
  }

  /* --- Buttons --- */

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero__content--center .hero__actions {
    justify-content: center;
  }

  .hero__content--right .hero__actions {
    justify-content: flex-end;
  }

  /* --- Button base --- */

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ btn_padding }};
    font-size: {{ btn_font_size }};
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wide);
    border-radius: var(--radius-btn);
    border: var(--border-width-thick) solid transparent;
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .btn--primary {
    background: var(--color-btn-bg);
    color: var(--color-btn-text);
    border-color: var(--color-btn-bg);
  }

  .btn--primary:hover {
    background: var(--color-btn-bg-hover);
    border-color: var(--color-btn-bg-hover);
    color: var(--color-btn-text);
  }

  .btn--secondary {
    background: transparent;
    color: {{ section.settings.text_color }};
    border-color: {{ section.settings.text_color }};
  }

  .btn--secondary:hover {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  /* --- Responsive --- */

  @media (max-width: 767px) {
    .hero {
      min-height: {{ section.settings.min_height_mobile }}vh;
    }

    .hero__subheading {
      font-size: var(--text-base);
    }
  }

  .hero__scroll-indicator {
    position: absolute;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    animation: hero-bounce 1.5s var(--ease-in-out) infinite;
  }

  @keyframes hero-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(8px); }
  }
{% endstyle %}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "placeholder": "New collection"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Welcome to our store",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "placeholder": "A short line that supports your heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "clamp(2.25rem, 3vw, 4.5rem)",
      "options": [
        { "value": "var(--text-2xl)", "label": "Small" },
        { "value": "var(--text-3xl)", "label": "Medium" },
        { "value": "clamp(2.25rem, 3vw, 4.5rem)", "label": "Large" },
        { "value": "clamp(3rem, 6vw, 5rem)", "label": "Extra large" }
      ]
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Primary button label",
      "placeholder": "Shop now"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Secondary button label",
      "placeholder": "Learn more"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "default": "medium",
      "options": [
        { "value": "small",  "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large",  "label": "Large" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Minimum height",
      "default": 80
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Minimum height (mobile)",
      "default": 50
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "default": "middle",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Centre" },
        { "value": "right",  "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Content max width",
      "default": 640
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": false
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#0a0a0a"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "bg_image_position",
      "label": "Image position",
      "default": "center center",
      "options": [
        { "value": "top left",      "label": "Top left" },
        { "value": "top center",    "label": "Top centre" },
        { "value": "top right",     "label": "Top right" },
        { "value": "center left",   "label": "Middle left" },
        { "value": "center center", "label": "Middle centre" },
        { "value": "center right",  "label": "Middle right" },
        { "value": "bottom left",   "label": "Bottom left" },
        { "value": "bottom center", "label": "Bottom centre" },
        { "value": "bottom right",  "label": "Bottom right" }
      ]
    },
    {
      "type": "text",
      "id": "bg_video",
      "label": "Background video URL",
      "info": "Direct link to an MP4 file. Use a hosted video URL."
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show dark overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay colour",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}