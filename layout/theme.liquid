<!doctype html>
<html
  lang="{{ request.locale.iso_code }}"
  class="no-js"
>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- comment -%} Page title {%- endcomment -%}
    {%- if page_title == blank -%}
      <title>{{ shop.name }}</title>
    {%- else -%}
      <title>
        {{ page_title }}
        {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
        {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
        {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
      </title>
    {%- endif -%}

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- unless settings.type_body_font.system? and settings.type_header_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    {%- comment -%} Shopify required — never remove {%- endcomment -%}
    {{ content_for_header }}

    {%- comment -%} Global theme settings — overrides tokens.css defaults {%- endcomment -%}
    <style>
      :root {
        {%- comment -%} Fonts {%- endcomment -%}
        --font-heading: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
        --font-body: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
        --font-body-style: {{ settings.type_body_font.style }};
        --font-body-weight: {{ settings.type_body_font.weight }};
        --font-heading-style: {{ settings.type_header_font.style }};
        --font-heading-weight: {{ settings.type_header_font.weight }};

        {%- comment -%} Font sizes {%- endcomment -%}
        --font-size-scale: {{ settings.body_base_size | divided_by: 16.0 }};
        --heading-scale: {{ settings.heading_base_size | divided_by: 100.0 }};

        {%- comment -%} Colours {%- endcomment -%}
        --color-primary:       {{ settings.color_primary }};
        --color-primary-hover: {{ settings.color_primary_hover }};
        --color-text:          {{ settings.color_text }};
        --color-text-subtle:   {{ settings.color_text_subtle }};
        --color-bg:            {{ settings.color_bg }};
        --color-bg-subtle:     {{ settings.color_bg_subtle }};
        --color-border:        {{ settings.color_border }};

        {%- comment -%} Buttons {%- endcomment -%}
        --radius-btn:         {{ settings.button_radius }};
        --color-btn-bg:       {{ settings.button_bg }};
        --color-btn-bg-hover: {{ settings.button_bg_hover }};
        --color-btn-text:     {{ settings.button_text }};

        {%- comment -%} Layout {%- endcomment -%}
        --layout-content-max: {{ settings.layout_content_max }}px;
      }

      {%- comment -%} Font face declarations {%- endcomment -%}
      {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {{ settings.type_header_font | font_face: font_display: 'swap' }}
    </style>

    {%- comment -%} Design tokens — always first {%- endcomment -%}
    {{ 'tokens.css' | asset_url | stylesheet_tag }}

    {%- comment -%} Base styles {%- endcomment -%}
    {{ 'base.css' | asset_url | stylesheet_tag }}

    {%- comment -%} JS/no-JS class swap + design mode flag {%- endcomment -%}
    <script>
      document.documentElement.classList.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
  </head>

  <body class="template-{{ template.name }}">

    <a class="skip-link" href="#main-content">Skip to content</a>

    <div id="page-wrapper">

      {%- sections 'header-group' -%}

      <main id="main-content" role="main" tabindex="-1">
        {{ content_for_layout }}
      </main>

      {%- sections 'footer-group' -%}

    </div>

    {%- comment -%} Accessibility announcer strings for JS {%- endcomment -%}
    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}'
      };
      window.Foundry = window.Foundry || {};
      window.Foundry.strings = {
        on_sale: {{ 'products.product.on_sale' | t | json }},
        sold_out: {{ 'products.product.sold_out' | t | json }},
        add_to_cart: {{ 'products.product.add_to_cart' | t | json }}
      };
    </script>

    <script src="{{ 'theme.js' | asset_url }}" defer></script>

  </body>
</html>