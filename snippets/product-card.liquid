{%- comment -%} snippets/product-card.liquid {%- endcomment -%}

{%- liquid
  if context_collection != blank
    assign card_url = product.url | within: context_collection
  else
    assign card_url = product.url
  endif
-%}

<article class="product-card">
  <a
    class="product-card__image-wrapper"
    href="{{ card_url }}"
    aria-label="{{ product.title | escape }}"
  >
    {%- if product.featured_image -%}
      {{
        product.featured_image
        | image_url: width: 600
        | image_tag:
          class: 'product-card__image',
          alt: product.featured_image.alt,
          loading: 'lazy',
          widths: '300, 450, 600'
      }}
    {%- else -%}
      <div class="product-card__image product-card__image--placeholder">
        {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
      </div>
    {%- endif -%}
  </a>

  <div class="product-card__info">
    <h2 class="product-card__title">
      <a href="{{ card_url }}">{{ product.title }}</a>
    </h2>

    <p class="product-card__price">
      {%- if product.compare_at_price > product.price -%}
        <s class="product-card__price--compare">{{ product.compare_at_price | money }}</s>
        <span class="product-card__price--sale">{{ product.price | money }}</span>
      {%- else -%}
        <span>{{ product.price | money }}</span>
      {%- endif -%}
    </p>
  </div>
</article>
