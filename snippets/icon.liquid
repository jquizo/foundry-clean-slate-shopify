{%- comment -%}
  snippets/icon.liquid
  Usage: {% render 'icon', icon: 'cart', size: 24, class: 'my-class' %}
  Parameters:
    icon  — (string, required) icon name
    size  — (number, default 24) width and height in px
    class — (string, optional) extra CSS classes on the <svg>
{%- endcomment -%}

{%- liquid
  assign icon_size = size | default: 24
-%}

<svg
  xmlns="http://www.w3.org/2000/svg"
  width="{{ icon_size }}"
  height="{{ icon_size }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  {%- if class != blank %} class="{{ class }}"{% endif %}
>
  {%- case icon -%}

    {%- when 'cart' -%}
      <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
      <line x1="3" y1="6" x2="21" y2="6"/>
      <path d="M16 10a4 4 0 0 1-8 0"/>

    {%- when 'menu' -%}
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>

    {%- when 'close' -%}
      <path d="M18 6 6 18"/>
      <path d="m6 6 12 12"/>

    {%- when 'search' -%}
      <circle cx="11" cy="11" r="8"/>
      <path d="m21 21-4.3-4.3"/>

    {%- when 'account' -%}
      <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
      <circle cx="12" cy="7" r="4"/>

    {%- when 'chevron-down' -%}
      <path d="m6 9 6 6 6-6"/>

    {%- when 'chevron-up' -%}
      <path d="m18 15-6-6-6 6"/>

    {%- when 'chevron-left' -%}
      <path d="m15 18-6-6 6-6"/>

    {%- when 'chevron-right' -%}
      <path d="m9 18 6-6-6-6"/>

    {%- when 'arrow-right' -%}
      <path d="M5 12h14"/>
      <path d="m12 5 7 7-7 7"/>

    {%- when 'check' -%}
      <path d="M20 6 9 17l-5-5"/>

    {%- when 'heart' -%}
      <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>

    {%- when 'plus' -%}
      <path d="M5 12h14"/>
      <path d="M12 5v14"/>

    {%- when 'minus' -%}
      <path d="M5 12h14"/>

    {%- when 'trash' -%}
      <path d="M3 6h18"/>
      <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
      <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
      <line x1="10" y1="11" x2="10" y2="17"/>
      <line x1="14" y1="11" x2="14" y2="17"/>

    {%- when 'star' -%}
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>

  {%- endcase -%}
</svg>
