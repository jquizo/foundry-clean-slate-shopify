{%- comment -%} templates/404.liquid {%- endcomment -%}

<div class="not-found">
  <div class="not-found__inner">
    <p class="not-found__code" aria-hidden="true">404</p>
    <h1 class="not-found__title">{{ 'templates.404.title' | t }}</h1>
    <p class="not-found__subtext">{{ 'templates.404.subtext' | t }}</p>
    <a href="{{ routes.root_url }}" class="not-found__link">
      {{ 'templates.404.link' | t }}
    </a>

    <form
      action="{{ routes.search_url }}"
      method="get"
      role="search"
      class="not-found__search"
    >
      <label for="not-found-search-input" class="visually-hidden">
        {{ 'templates.search.placeholder' | t }}
      </label>
      <input
        id="not-found-search-input"
        type="search"
        name="q"
        class="not-found__search-input"
        placeholder="{{ 'templates.search.placeholder' | t }}"
        autocomplete="off"
        spellcheck="false"
      >
      <button type="submit" class="not-found__search-btn" aria-label="{{ 'templates.search.title' | t }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
    </form>
  </div>
</div>

{% style %}
  .not-found {
    padding-block: var(--section-padding-block);
    padding-inline: var(--section-padding-inline);
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .not-found__inner {
    max-width: var(--layout-text-max);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .not-found__code {
    font-size: var(--text-4xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    color: var(--color-text-muted);
  }

  .not-found__title {
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .not-found__subtext {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-subtle);
  }

  .not-found__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-8);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary-text);
    background-color: var(--color-primary);
    border-radius: var(--radius-md);
    transition:
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .not-found__link:hover {
    background-color: var(--color-primary-hover);
    color: var(--color-primary-text);
  }

  .not-found__search {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 360px;
    margin-top: var(--space-4);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-bg);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .not-found__search:focus-within {
    border-color: var(--color-border-strong);
  }

  .not-found__search-input {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: transparent;
    border: none;
    outline: none;
  }

  .not-found__search-input::placeholder {
    color: var(--color-text-muted);
  }

  .not-found__search-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3);
    color: var(--color-text-subtle);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .not-found__search-btn:hover {
    color: var(--color-text);
  }
{% endstyle %}
